{
  "name": "@drift/engine-linux-arm64-gnu",
  "version": "0.1.0",
  "description": "Drift Rust engine binary for Linux arm64 glibc.",
  "license": "MIT",
  "os": [
    "linux"
  ],
  "cpu": [
    "arm64"
  ],
  "libc": [
    "glibc"
  ],
  "bin": {
    "drift-engine": "./bin/drift-engine"
  },
  "files": [
    "bin",
    "engine-manifest.json",
    "README.md"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-engine-package.mjs --target aarch64-unknown-linux-gnu --platform linux --arch arm64 --binary-name drift-engine"
  }
}
