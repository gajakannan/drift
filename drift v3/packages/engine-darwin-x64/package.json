{
  "name": "@drift/engine-darwin-x64",
  "version": "0.1.0",
  "description": "Drift Rust engine binary for macOS x64.",
  "license": "MIT",
  "os": [
    "darwin"
  ],
  "cpu": [
    "x64"
  ],
  "bin": {
    "drift-engine": "./bin/drift-engine"
  },
  "files": [
