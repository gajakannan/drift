{
  "name": "@drift/mcp",
  "version": "0.1.0",
  "description": "Read-only local MCP server for Drift repo contracts, scan status, findings, and preflight.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "drift-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@drift/core": "workspace:*",
    "@drift/query": "workspace:*",
    "@drift/storage": "workspace:*"
  },
  "devDependencies": {
    "@drift/factgraph": "workspace:*",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
